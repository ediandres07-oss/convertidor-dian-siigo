# DATABASE
DATABASE_URL=postgresql://user:password@postgres:5432/cloudapp_db
SQLALCHEMY_DATABASE_URL=postgresql://user:password@postgres:5432/cloudapp_db

# JWT & SECURITY
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 / CLOUD STORAGE
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=cloudapp-storage-bucket
S3_ENDPOINT_URL=https://s3.amazonaws.com

# AZURE ALTERNATIVE
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_CONTAINER_NAME=cloudapp-container

# GCP ALTERNATIVE
# GCP_PROJECT_ID=your-gcp-project
# GCP_BUCKET_NAME=cloudapp-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# EMAIL
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@cloudapp.com

# BACKEND
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WORKERS=4
DEBUG=False
ENVIRONMENT=production

# FRONTEND
REACT_APP_API_URL=https://api.cloudapp.com
REACT_APP_WEBSOCKET_URL=wss://api.cloudapp.com
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=https://cloudapp.com,https://www.cloudapp.com
CORS_ALLOW_CREDENTIALS=true

# REDIS (optional - for caching/sessions)
REDIS_URL=redis://redis:6379/0

# FEATURES
ENABLE_USER_REGISTRATION=true
ENABLE_TWO_FACTOR_AUTH=false
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,xlsx,docx,txt,csv

# MONITORING
SENTRY_DSN=
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=
